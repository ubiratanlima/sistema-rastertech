APP_NAME=Sistema-Rastertech
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (PostgreSQL inside Supabase stack)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis (Queues and Cache)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Supabase (Self-hosted)
SUPABASE_URL=http://localhost:8000
SUPABASE_API_KEY=
SUPABASE_STORAGE_URL=http://localhost:8000/storage/v1

# AdminLTE Path (Blade integration)
ADMINLTE_THEME_COLOR=green
ADMINLTE_SIDEBAR_NAV_DARK=true
